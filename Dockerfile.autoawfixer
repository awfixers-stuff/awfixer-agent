# syntax=docker/dockerfile:1.7-labs
###############################################################################
# autoawfixer — GitHub triage+fix bot orchestrator.
#
# Extends `pi-base` (from /Dockerfile, default target awfixer-agent/agent:dev) and adds
# the autoawfixer Python package + a Vite-built SolidJS dashboard bundle. The pi
# toolchain (python + bun + rustup launcher + pi-natives + omp_rpc wheel +
# /usr/local/bin/omp shim) all comes from PI_BASE; this file only layers what's
# autoawfixer-specific.
#
# Build (from pi root):
#     bun run agent:image                              # build awfixer-agent/agent:dev first
#     docker build -f Dockerfile.autoawfixer -t autoawfixer:dev .
#
# Compose (recommended):
#     docker compose --project-directory python/autoawfixer build
###############################################################################

ARG PI_BASE=awfixer-agent/agent:dev
ARG BUN_VERSION=1.3.14

############################
# 1) web-builder — Bun + Vite, builds the SolidJS dashboard bundle.
############################
FROM oven/bun:${BUN_VERSION}-slim AS web-builder
WORKDIR /work
# Root manifests + the web workspace manifest are enough for `bun install
# --filter autoawfixer-web` to hydrate just the dashboard's node_modules.
COPY package.json bun.lock ./
COPY python/autoawfixer/web/package.json ./python/autoawfixer/web/package.json
# Root package.json declares patchedDependencies, so the patch file must be
# present before any root-level `bun install` (even a filtered one).
COPY patches/*.patch ./patches/
RUN bun install --filter autoawfixer-web
COPY --exclude=node_modules --exclude=dist python/autoawfixer/web/ ./python/autoawfixer/web/
RUN bun --cwd=python/autoawfixer/web run build

############################
# 2) runtime — pi-base + autoawfixer src + web bundle + pip install
############################
FROM ${PI_BASE} AS runtime

# autoawfixer runs against the host pi checkout mounted at /work/pi read-only.
ENV AGENT_ROOT=/work/pi

WORKDIR /app

# autoawfixer itself. Drop the Vite-built dashboard into the package tree before
# `uv sync` so it lands in the installed wheel (`static/**/*` is declared
# as package-data in pyproject.toml).
COPY --from=ghcr.io/astral-sh/uv:0.11 /uv /uvx /bin/

COPY python/uv.lock python/pyproject.toml ./
COPY python/autoawfixer/pyproject.toml ./autoawfixer/
COPY python/omp-rpc/pyproject.toml ./omp-rpc/
COPY python/omp-rpc/src ./omp-rpc/src/
COPY python/autoawfixer/src ./autoawfixer/src/
COPY --from=web-builder /work/python/autoawfixer/web/dist/ ./autoawfixer/src/static/

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never

RUN uv sync --frozen --package autoawfixer --no-dev --no-editable

# Host agent config is mounted read-only under /srv/agent-home-stage with
# host-controlled permissions. The entrypoint copies it into root-owned
# world-readable files under /srv/agent-home; the agent subprocess runs with
# HOME=/srv/agent-home, so ~/.omp and ~/.agent resolve there without exposing
# mutable host mounts.
RUN mkdir -p /srv/agent-home/.agent /srv/agent-home/.omp/agent \
    && mkdir -p /srv/agent-home-stage/.agent /srv/agent-home-stage/.omp/agent \
    && printf '[install]\nbackend = "copyfile"\n' > /srv/agent-home/.bunfig.toml

COPY python/autoawfixer/entrypoint.sh /usr/local/bin/autoawfixer-entrypoint
RUN chmod +x /usr/local/bin/autoawfixer-entrypoint

VOLUME ["/data"]
EXPOSE 8080
EXPOSE 8081

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/autoawfixer-entrypoint"]
CMD ["uv", "run", "--package", "autoawfixer", "autoawfixer", "serve"]
