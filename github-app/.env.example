# === Shared (gateway + worker) ===
DATABASE_URL=postgresql://user:pass@localhost:5432/prwatch

# GitHub App (register app; install on org/repos)
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# PEM body (use Railway variable; escape newlines or paste multiline)
GITHUB_APP_PRIVATE_KEY=

# === Gateway only ===
PRWATCH_BIND_ADDR=:8080
PRWATCH_MIGRATE_ON_START=true

# === Worker only ===
PRWATCH_WORKER_ID=worker-1
PRWATCH_MAX_CONCURRENCY=4
PRWATCH_OMP_COMMAND=omp
PRWATCH_WORKSPACE_ROOT=/data/workspaces
E2B_API_KEY=
# Optional v1.1
# KERNEL_API_KEY=