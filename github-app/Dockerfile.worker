# syntax=docker/dockerfile:1
# Build from monorepo root: docker build -f github-app/Dockerfile.worker --build-arg AGENT_BASE=awfixer-agent/agent:dev .
ARG PI_BASE
ARG AGENT_BASE
ARG BASE_IMAGE=${AGENT_BASE:-${PI_BASE:-awfixer-agent/agent:dev}}
FROM ${BASE_IMAGE} AS pi

ARG PI_BASE
ARG AGENT_BASE
RUN if [ -z "${AGENT_BASE}" ] && [ -n "${PI_BASE}" ]; then \
      echo "[deprecated] Docker build-arg PI_BASE is deprecated; use AGENT_BASE instead." >&2; \
    fi

FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY github-app/worker/pyproject.toml github-app/worker/README.md ./
COPY github-app/worker/src ./src
COPY python/omp-rpc /tmp/omp-rpc
RUN pip install --no-cache-dir /tmp/omp-rpc . \
  && rm -rf /tmp/omp-rpc
COPY --from=pi /usr/local/bin/omp /usr/local/bin/omp
COPY --from=pi /usr/local/bin/agent /usr/local/bin/agent
ENV PRWATCH_OMP_COMMAND=agent
ENV PRWATCH_WORKSPACE_ROOT=/data/workspaces
VOLUME /data
ENTRYPOINT ["prwatch"]
CMD ["worker"]