{
  "type": "module",
  "name": "@awfixerai/agent-api",
  "version": "0.0.0",
  "private": true,
  "description": "Vercel-hosted update API for awfixer-agent (npm proxy, install script, release assets, grievances receiver)",
  "homepage": "https://agent.awfixer.codes",
  "scripts": {
    "dev": "bun --hot server.ts",
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write .",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.8.9"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
