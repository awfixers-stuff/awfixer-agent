{
	"installCommand": "bun install",
	"headers": [
		{
			"source": "/install",
			"headers": [
				{
					"key": "Content-Type",
					"value": "text/plain; charset=utf-8"
				},
				{
					"key": "Cache-Control",
					"value": "public, max-age=300"
				}
			]
		},
		{
			"source": "/@awfixerai/(.*)/latest",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=60"
				}
			]
		}
	]
}