{
  "type": "module",
  "name": "@awfixerai/swarm-extension",
  "version": "0.0.0",
  "description": "Swarm orchestration extension for omp",
  "homepage": "https://agent.awfixer.codes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awfixers-stuff/awfixer-agent.git",
    "directory": "packages/swarm-extension"
  },
  "bugs": {
    "url": "https://github.com/awfixers-stuff/awfixer-agent/issues"
  },
  "keywords": [
    "swarm",
    "orchestration",
    "agent",
    "extension"
  ],
  "bin": {
    "omp-swarm": "src/cli.ts"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@awfixerai/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "@awfixerai/agent": "^13"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "omp": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ]
}
