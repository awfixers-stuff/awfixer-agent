{
  "type": "module",
  "name": "@awfixerai/utils",
  "version": "0.0.1-rc.1",
  "description": "Shared utilities for pi packages",
  "homepage": "https://agent.awfixer.codes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awfixers-stuff/awfixer-agent.git",
    "directory": "packages/utils"
  },
  "bugs": {
    "url": "https://github.com/awfixers-stuff/awfixer-agent/issues"
  },
  "keywords": [
    "utilities",
    "cli",
    "logging",
    "streams"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@awfixerai/natives": "catalog:",
    "handlebars": "catalog:",
    "winston": "catalog:",
    "winston-daily-rotate-file": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*.js": "./src/*.ts"
  }
}
